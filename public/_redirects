# Sanity Studio — serve index.html for all sub-paths (client-side routing)
/studio/* /studio/index.html 200

# Canonicalize accidental trailing slash on common static files
/favicon.ico/ /favicon.ico 301
/favicon-32x32.png/ /favicon-32x32.png 301
/apple-touch-icon.png/ /apple-touch-icon.png 301
/logortvfontana.jpg/ /logortvfontana.jpg 301
/cdn-cgi/l/email-protection /kontakt/ 302
/cdn-cgi/l/email-protection/ /kontakt/ 302

# Ensure the /lajme listing page resolves in both URL forms.
/lajme /lajme/index.html 200
/lajme/ /lajme/index.html 200

# Ensure top-level pages resolve in both URL forms.
/live /live/index.html 200
/live/ /live/index.html 200
/kontakt /kontakt/index.html 200
/kontakt/ /kontakt/index.html 200

# Legal / about pages — accept the no-trailing-slash form too.
/cookies /cookies/index.html 200
/privacy /privacy/index.html 200
/terms /terms/index.html 200
/gdpr /gdpr/index.html 200
/disclaimer /disclaimer/index.html 200
/rreth-nesh /rreth-nesh/index.html 200

# Article slugs that don't have a static page fall through to the fallback
# shell (/lajme/_/index.html). The shell uses ArticleClient to fetch the
# article from /api/article so newly-published Sanity content shows up
# immediately, before the next build runs.
/lajme/* /lajme/_/index.html 200

# Fallback to 404 page for unmatched routes
/* /404.html 404
